# ═══════════════════════════════════════════════════════════════════
# S7 SkyQUBi — Pod Secrets Template
# Copy to .env.secrets and fill in strong random values.
# NEVER commit .env.secrets — it is gitignored.
#
# Generate passwords:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Quick setup:
#   cp .env.example .env.secrets
#   # Edit .env.secrets with real values
#   ./start-pod.sh
# ═══════════════════════════════════════════════════════════════════

# ── MySQL (Admin UI database) ────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME
MYSQL_USER=nomad_user
MYSQL_DATABASE=nomad

# ── PostgreSQL (CWS Engine database) ─────────────────────────────
POSTGRES_USER=s7
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=s7_cws

# ── Admin App ────────────────────────────────────────────────────
APP_KEY=CHANGE_ME

# ── CWS Engine ───────────────────────────────────────────────────
CWS_ENGINE_TOKEN=CHANGE_ME
CWS_DB_HOST=127.0.0.1
CWS_DB_PORT=5432
CWS_DB_NAME=s7_cws
CWS_DB_USER=s7
CWS_DB_PASS=CHANGE_ME

# ── Service URLs (internal to pod) ───────────────────────────────
CWS_ENGINE_URL=http://127.0.0.1:7077

# ── Paths (auto-detected by start-pod.sh if not set) ────────────
# SKYQUBI_STORAGE=~/.skyqubi/data
# SKYQUBI_SQL=./engine/sql
# PODMAN_SOCK=/run/user/$(id -u)/podman/podman.sock
