[Unit]
Description=S7 SkyQUBi — Public Chat Service (standalone, separate from CWS stack)
Documentation=file:///s7/skyqubi-private/public-chat/README.md
After=network.target s7-ollama.service
Wants=s7-ollama.service

[Service]
Type=simple
WorkingDirectory=/s7/skyqubi-private/public-chat
Environment=S7_OLLAMA_URL=http://127.0.0.1:57081
Environment=S7_PUBLIC_MODEL=qwen2.5:3b
ExecStart=/usr/bin/python3 /s7/skyqubi-private/public-chat/app.py
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadOnlyPaths=/s7/skyqubi-private/public-chat
ProtectHome=read-only
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=default.target
