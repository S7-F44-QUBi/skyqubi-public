[Unit]
Description=S7 Audit Snapshot every 15 minutes
Documentation=https://github.com/skycair-code/SkyQUBi-public

[Timer]
# First run 2 minutes after boot, then every 15 minutes.
OnBootSec=2min
OnUnitActiveSec=15min
AccuracySec=1min
Persistent=true
Unit=s7-audit-snapshot.service

[Install]
WantedBy=timers.target
