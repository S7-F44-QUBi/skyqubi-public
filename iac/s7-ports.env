# S7 Port Range — Canonical Shared Config
#
# The single source of truth for every port number in the S7
# SkyQUBi appliance. Every launcher, every systemd unit, every
# script, every Python module that needs a port number should
# source this file (or read the corresponding environment
# variable) rather than hardcoding a literal.
#
# Why this file exists: 2026-04-14 multi-launcher drift findings.
# Three separate services had port drift because each launcher
# hardcoded the port independently:
#   - Ollama: 7081 (legacy) vs 57081 (canonical)
#   - CWS engine: 7077 (legacy) vs 57077 (canonical)
#   - Monitor baseline: EXPECTED_PORTS had some wrong entries
# Each was a hardcoded literal in a different file. The fix is
# to have exactly one place where the port is declared, and every
# consumer reads from here.
#
# The S7 port range convention: all internal services live on
# 57xxx (five-seven-thousand-anything). The legacy 7xxx range
# (ports 7000-8999) is deprecated and should not be used for new
# services. External-facing public ports (8080 for Caddy front
# door) are exempt from the 57xxx rule because they're
# household-visible and follow web conventions.
#
# Usage in bash:
#   source /s7/skyqubi-private/iac/s7-ports.env
#   # now $S7_OLLAMA_PORT, etc. are available
#
# Usage in Python:
#   import os
#   port = int(os.getenv("S7_OLLAMA_PORT", "57081"))
#
# Usage in systemd unit Environment= directive:
#   EnvironmentFile=/s7/skyqubi-private/iac/s7-ports.env
#
# When modifying: any change to this file is a tier-crossing
# audit artifact. The commit that changes it is visible in git
# log; the gate sees the change via the frozen-trees.txt pin
# advance that follows.

# ─────────────────────────────────────────────────────────────
# Inference and AI services
# ─────────────────────────────────────────────────────────────
S7_OLLAMA_PORT=57081
S7_OLLAMA_HOST=127.0.0.1
S7_OLLAMA_URL=http://${S7_OLLAMA_HOST}:${S7_OLLAMA_PORT}

S7_BITNET_PORT=57083
S7_BITNET_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────
# Data services (pod-internal, exposed via rootlessport on loopback)
# ─────────────────────────────────────────────────────────────
S7_POSTGRES_PORT=57090
S7_POSTGRES_HOST=127.0.0.1

S7_QDRANT_PORT=57086
S7_QDRANT_HOST=127.0.0.1

S7_REDIS_PORT=57085
S7_REDIS_HOST=127.0.0.1

S7_MYSQL_PORT=57087
S7_MYSQL_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────
# S7 engine services
# ─────────────────────────────────────────────────────────────
S7_CWS_PORT=57077
S7_CWS_HOST=127.0.0.1

S7_PERSONA_CHAT_PORT=57082
S7_PERSONA_CHAT_HOST=127.0.0.1

S7_PUBLIC_CHAT_PORT=57088
S7_PUBLIC_CHAT_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────
# Admin and management
# ─────────────────────────────────────────────────────────────
S7_NOMAD_ADMIN_PORT=57080
S7_NOMAD_ADMIN_HOST=127.0.0.1

S7_CADDY_ADMIN_PORT=2019
S7_CADDY_ADMIN_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────
# Public-facing (household surface — exempt from 57xxx rule
# because they're household-visible and follow web conventions)
# ─────────────────────────────────────────────────────────────
S7_CADDY_FRONT_DOOR_PORT=8080
# S7_CADDY_FRONT_DOOR_HOST intentionally NOT 127.0.0.1 —
# Caddy is the public-facing reverse proxy. Currently wildcard-
# bound (pinned as awareness in iac/audit/pinned.yaml).

# ─────────────────────────────────────────────────────────────
# Static app containers (8xxx range, public-adjacent)
# ─────────────────────────────────────────────────────────────
S7_KIWIX_PORT=8090
S7_JELLYFIN_PORT=8096
S7_CYBERCHEF_PORT=8100
S7_FLATNOTES_PORT=8200
S7_KOLIBRI_PORT=8300
